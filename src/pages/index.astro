---
import Base from '../layouts/Base.astro';
---
<Base title="UAA Plasma Physics Laboratory" description="Plasma physics research and teaching at the University of Alaska Anchorage — electric propulsion plasma diagnostics, multipole multicusp plasma confinement, and undergraduate education and outreach.">
  <section class="hero">
    <h1>UAA Plasma Physics Laboratory</h1>
    <p class="lede">
      Plasma physics research and teaching at the University of Alaska
      Anchorage: diagnostics for electric propulsion, RF confinement of
      quasi-neutral plasmas, and mentorship of undergraduate student plasma researchers.
    </p>
  </section>

  <section class="threads">
    <h2>Research</h2>
    <div class="grid">
      <a href="/research/eppd/" class="card">
        <h3>Electric Propulsion Plasma Diagnostics</h3>
        <p>RF plasma diagnostic development for electric propulsion (NASA / JPL).</p>
      </a>
      <a href="/research/mmpt/" class="card">
        <h3>Multipole Multicusp Plasma Trap</h3>
        <p>RF multipole multicusp confinement of quasi-neutral plasmas.</p>
      </a>
      <a href="/research/pto/" class="card">
        <h3>Plasma Teaching and Outreach</h3>
        <p>Undergraduate plasma physics education and community outreach.</p>
      </a>
    </div>
  </section>
</Base>

<style>
.hero { padding-top: 1rem; }
.lede {
  font-size: 1.15rem;
  color: var(--color-text);
  margin-bottom: 2.5rem;
  max-width: var(--measure);
}
.threads h2 { margin-top: 2rem; }
.grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  margin-top: 1rem;
}
@media (min-width: 48rem) {
  .grid { grid-template-columns: repeat(3, 1fr); }
}
.card {
  display: block;
  padding: 1.25rem;
  border: 1px solid var(--color-border);
  border-radius: 6px;
  background: white;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.15s, transform 0.15s;
}
.card:hover, .card:focus-visible {
  border-color: var(--color-accent);
  transform: translateY(-2px);
}
.card h3 {
  margin-top: 0;
  color: var(--color-accent-dark);
}
.card p {
  color: var(--color-text-muted);
  margin-bottom: 0;
  max-width: none;
}
</style>
