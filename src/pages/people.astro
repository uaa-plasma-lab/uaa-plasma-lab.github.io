---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const members = await getCollection('members');
const active = members.filter(m => m.data.status === 'active');

const ROLE_ORDER: Record<string, number> = {
  'Principal Investigator': 0,
  'Lab Director': 1,
  'Graduate Student Researcher': 2,
  'Undergraduate Student Researcher': 3,
};

const rolePriority = (role: string | string[]): number => {
  const list = Array.isArray(role) ? role : [role];
  return Math.min(...list.map(r => ROLE_ORDER[r] ?? 99));
};

const roleDisplay = (role: string | string[]): string =>
  Array.isArray(role) ? role.join(' · ') : role;

const initials = (name: string): string =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .map(part => part[0]?.toUpperCase() ?? '')
    .slice(0, 2)
    .join('');

active.sort((a, b) => {
  const r = rolePriority(a.data.role) - rolePriority(b.data.role);
  if (r !== 0) return r;
  return a.data.name.localeCompare(b.data.name);
});
---
<Base title="People" description="Members of the UAA Plasma Lab.">
  <h1>People</h1>

  {active.length === 0 && <p>No active members listed yet.</p>}

  <ul class="people-grid">
    {active.map(m => (
      <li>
        <a href={`/people/${m.id}/`} class="card">
          {m.data.photo ? (
            <Image
              class="photo"
              src={m.data.photo}
              alt=""
              width={160}
              height={160}
            />
          ) : (
            <div class="photo placeholder" aria-hidden="true">{initials(m.data.name)}</div>
          )}
          <div class="info">
            <h2>{m.data.name}</h2>
            <p class="role">{roleDisplay(m.data.role)}</p>
            {m.data.affiliation && <p class="affiliation">{m.data.affiliation}</p>}
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
.people-grid {
  list-style: none;
  padding: 0;
  margin: 1.5rem 0 0;
  max-width: none;
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 36rem) {
  .people-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 60rem) {
  .people-grid { grid-template-columns: repeat(3, 1fr); }
}
.card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  background: white;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.15s, transform 0.15s;
  height: 100%;
}
.card:hover, .card:focus-visible {
  border-color: var(--color-accent);
  transform: translateY(-2px);
}
.photo {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  background: var(--color-bg);
}
.photo.placeholder {
  background: var(--color-accent-light);
  color: var(--color-accent-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 1.2rem;
  border: 1px dashed var(--color-border);
}
.info { min-width: 0; }
.info h2 {
  margin: 0 0 0.15rem;
  font-size: 1.1rem;
  color: var(--color-text);
}
.role {
  color: var(--color-text-muted);
  font-size: 0.9rem;
  margin: 0 0 0.15rem;
  max-width: none;
}
.affiliation {
  color: var(--color-text-muted);
  font-size: 0.9rem;
  margin: 0;
  font-style: italic;
  max-width: none;
}
</style>
