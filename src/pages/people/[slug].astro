---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const members = await getCollection('members');
  return members.map(m => ({ params: { slug: m.id }, props: { member: m } }));
}

const { member } = Astro.props;
const { Content } = await render(member);

const roleDisplay = (role: string | string[]): string =>
  Array.isArray(role) ? role.join(' · ') : role;
---
<Base
  title={member.data.name}
  description={`${member.data.name} — ${roleDisplay(member.data.role)}, UAA Plasma Lab`}
>
  <p class="back-link"><a href="/people/">← All people</a></p>

  <article class="member-detail">
    {member.data.photo && (
      <Image
        class="photo"
        src={member.data.photo}
        alt={`Portrait of ${member.data.name}`}
        width={280}
        height={280}
      />
    )}
    <div class="meta">
      <h1>{member.data.name}</h1>
      <p class="role">{roleDisplay(member.data.role)}</p>
      {member.data.affiliation && <p class="affiliation">{member.data.affiliation}</p>}
      {(member.data.email || member.data.website) && (
        <p class="links">
          {member.data.website && <a href={member.data.website}>Website</a>}
          {member.data.website && member.data.email && <span aria-hidden="true"> · </span>}
          {member.data.email && <a href={`mailto:${member.data.email}`}>{member.data.email}</a>}
        </p>
      )}
    </div>
    <div class="bio">
      <Content />
    </div>
  </article>
</Base>

<style>
.back-link { margin: 0 0 1rem; font-size: 0.95rem; }

.member-detail {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
}
@media (min-width: 40rem) {
  .member-detail {
    grid-template-columns: 280px 1fr;
    grid-template-areas:
      "photo meta"
      "bio bio";
    gap: 1.5rem 2rem;
  }
  .photo { grid-area: photo; }
  .meta { grid-area: meta; align-self: start; }
  .bio { grid-area: bio; }
}

.photo {
  width: 100%;
  max-width: 280px;
  height: auto;
  border-radius: 6px;
}

.meta h1 { margin: 0 0 0.25rem; font-size: 1.6rem; }
.role {
  color: var(--color-text-muted);
  margin: 0 0 0.25rem;
  max-width: none;
}
.affiliation {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  margin: 0 0 0.5rem;
  font-style: italic;
  max-width: none;
}
.links { margin: 0.5rem 0 0; font-size: 0.95rem; max-width: none; }
.bio { margin-top: 1rem; }
.bio :global(h2) { font-size: 1.15rem; margin-top: 1.5em; margin-bottom: 0.4em; }
.bio :global(p) { margin: 0.6em 0; }
.bio :global(ul) { padding-left: 1.25em; }
.bio :global(li) { margin: 0.2em 0; }
</style>
